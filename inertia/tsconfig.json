{
  "extends": "@adonisjs/tsconfig/tsconfig.client.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["vite/client"],
    "paths": {
      "~/*": [
        "./*"
      ],
      "@generated/*": [
        "../.adonisjs/client/*"
      ]
    }
  },
  "include": [
    "./**/*.ts",
    "./**/*.d.ts",
    "../.adonisjs/client/**/*.ts",
    "../.adonisjs/server/**/*.ts",
    "app.ts"
  ]
}
